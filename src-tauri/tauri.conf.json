{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FotoCarnet",
  "version": "1.0.0",
  "identifier": "com.renato.fotocarnet",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "FotoCarnet",
        "width": 1500,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 760,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
